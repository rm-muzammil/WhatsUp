{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "../../",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@whatsapp-clone/types": ["../../packages/types/index.ts"]
    }
  },
  "include": [
    "src",
    "../../packages/types"
  ],
  "exclude": ["node_modules", "dist"]
}